# Environment Configuration
# Controls environment-specific behavior (CORS, logging, etc.)
# Values: "production" (strict security), "staging" (permissive), "dev" (permissive)
# Default: "production" (fail-safe)
# IMPORTANT: Set to "production" in production environments for security
ENV={{ENV}}

# App setting
APP_VERSION={{APP_VERSION}}

# HTTP Server Configuration
HOST={{HOST}}
APP_PORT={{APP_PORT}}
API_MODE={{API_MODE}}

# Logger Configuration
LOGGER_LEVEL={{LOGGER_LEVEL}}
LOGGER_MODE={{LOGGER_MODE}}
LOGGER_ENCODING={{LOGGER_ENCODING}}

# PostgreSQL Configuration
POSTGRES_HOST={{POSTGRES_HOST}}
POSTGRES_PORT={{POSTGRES_PORT}}
POSTGRES_USER={{POSTGRES_USER}}
POSTGRES_PASSWORD={{POSTGRES_PASSWORD}}
POSTGRES_DB={{POSTGRES_DB}}
POSTGRES_SSLMODE={{POSTGRES_SSLMODE}}

# MinIO Configuration
MINIO_ENDPOINT={{MINIO_ENDPOINT}}
MINIO_ACCESS_KEY={{MINIO_ACCESS_KEY}}
MINIO_SECRET_KEY={{MINIO_SECRET_KEY}}
MINIO_USE_SSL={{MINIO_USE_SSL}}
MINIO_REGION={{MINIO_REGION}}
MINIO_BUCKET={{MINIO_BUCKET}}
MINIO_ASYNC_UPLOAD_WORKERS={{MINIO_ASYNC_UPLOAD_WORKERS}}
MINIO_ASYNC_UPLOAD_QUEUE_SIZE={{MINIO_ASYNC_UPLOAD_QUEUE_SIZE}}

# RabbitMQ Configuration
RABBITMQ_URL={{RABBITMQ_URL}}

# JWT Configuration
JWT_SECRET={{JWT_SECRET}}

# Cookie Configuration (for HttpOnly authentication)
COOKIE_DOMAIN={{COOKIE_DOMAIN}}
COOKIE_SECURE={{COOKIE_SECURE}}
COOKIE_SAMESITE={{COOKIE_SAMESITE}}
COOKIE_MAX_AGE={{COOKIE_MAX_AGE}}
COOKIE_MAX_AGE_REMEMBER={{COOKIE_MAX_AGE_REMEMBER}}
COOKIE_NAME={{COOKIE_NAME}}

# Encrypter Configuration
ENCRYPT_KEY={{ENCRYPT_KEY}}

# Internal Configuration
INTERNAL_KEY={{INTERNAL_KEY}}

# Discord Configuration
DISCORD_WEBHOOK_ID={{DISCORD_WEBHOOK_ID}}
DISCORD_WEBHOOK_TOKEN={{DISCORD_WEBHOOK_TOKEN}}

# LLM Configuration
# Provider: gemini (default), openai (future)
LLM_PROVIDER=gemini
# API Key: Required for service startup. Get from https://aistudio.google.com/apikey
LLM_API_KEY={{LLM_API_KEY}}
# Model: gemini-1.5-flash (default), gemini-1.5-pro, gemini-2.0-flash-exp
LLM_MODEL=gemini-2.0-flash
# Timeout in seconds for LLM API calls
LLM_TIMEOUT=30
# Max retries for transient failures (network errors, 5xx)
LLM_MAX_RETRIES=3

# Collector Service Configuration
# For production, set COLLECTOR_SERVICE_URL to actual Collector Service URL
COLLECTOR_SERVICE_URL=http://localhost:8081
COLLECTOR_TIMEOUT=30

# Redis State Configuration
# Separate Redis DB for state management (different from main DB)
# DB 0 = Main (job mapping, pub/sub for dry-run notifications)
# DB 1 = State (project progress tracking) - requires noeviction policy
REDIS_STATE_DB=1